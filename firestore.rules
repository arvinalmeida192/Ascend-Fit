rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: own profile read/write; all authenticated users can read (for leaderboard)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Workouts: user owns their own data
    // CRITICAL: list queries need 'list' permission checked against request.auth, not resource.data
    match /workouts/{workoutId} {
      allow list: if request.auth != null;
      allow get: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Nutrition logs: private per user
    match /nutrition/{entryId} {
      allow list: if request.auth != null;
      allow get: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Dishes: private per user
    match /dishes/{dishId} {
      allow list: if request.auth != null;
      allow get: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}